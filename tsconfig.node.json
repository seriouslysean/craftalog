{
  // Type-checks scripts/ and tests/, which the root tsconfig excludes from
  // `astro check` (tsx and Vitest execute them without checking types).
  // Extends the same Astro strict preset as the site so transitively-imported
  // src/ modules resolve identically; bundler moduleResolution matches how
  // tsx (esbuild) and Vitest actually resolve the extensionless imports here.
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "types": ["node"]
  },
  // .astro/types.d.ts supplies the astro:content module types needed by
  // src/content.config.ts (imported transitively via src/utils). It's
  // generated by `astro sync`/`astro check`, which type-check runs first.
  "include": [".astro/types.d.ts", "scripts/**/*.ts", "tests/**/*.ts"]
}
