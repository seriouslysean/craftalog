---
import ItemCard from './ItemCard.astro';
import ItemIcon from './ItemIcon.astro';
import { withBase } from '../utils/with-base';
import type { ItemData } from '../content.config';

interface Props {
  item: ItemData;
  /** This item's own recipe path (bare, base-agnostic -- see buildRecipeHrefMap), or null if it isn't craftable in this catalog. */
  recipePath: string | null;
  loading?: 'lazy' | 'eager';
}

const { item, recipePath, loading } = Astro.props;
---

<span class="item-icon-tooltip">
  {
    /* The visible icon itself is the interactive element: when the item has a
       recipe, the trigger IS the jump-to-recipe link (in the tab order, and
       directly tappable for touch users). The popup card is purely visual
       description of that link -- aria-hidden, never focusable -- revealed on
       trigger hover AND keyboard focus via :focus-within below. */
    recipePath ? (
      <a
        class="item-icon-tooltip__trigger"
        href={withBase(recipePath)}
        aria-label={`${item.name} recipe`}
      >
        <ItemIcon item={item} loading={loading} />
      </a>
    ) : (
      <span class="item-icon-tooltip__trigger">
        <ItemIcon item={item} loading={loading} />
      </span>
    )
  }
  <span class="item-icon-tooltip__popup" aria-hidden="true">
    <ItemCard href={null} item={item} name={item.name} variant="tooltip" />
  </span>
</span>

<style>
  .item-icon-tooltip {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .item-icon-tooltip__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    /* Opt out of the global link underline -- the trigger is an icon, not text. */
    border: none;
  }

  a.item-icon-tooltip__trigger:focus-visible {
    outline: 2px solid var(--color-fg);
    outline-offset: 2px;
  }

  .item-icon-tooltip__popup {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translate(-50%, -0.5rem);
    z-index: 20;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    white-space: nowrap;
    transition: opacity 0.1s ease;
  }

  .item-icon-tooltip:hover .item-icon-tooltip__popup,
  .item-icon-tooltip:focus-within .item-icon-tooltip__popup {
    opacity: 1;
    visibility: visible;
    /* Hover-revealed content must stay up while the pointer moves over it
       (WCAG 1.4.13): accepting pointer events keeps the container :hover
       alive when the cursor crosses onto the popup itself. */
    pointer-events: auto;
  }
</style>
