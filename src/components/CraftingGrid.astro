---
import ItemIconTooltip from './ItemIconTooltip.astro';
import ItemVariants from './ItemVariants.astro';
import type { GridCell } from '../utils/crafting-grid';
import type { ItemData, RecipeResult } from '../content.config';

interface Props {
  cells: GridCell[];
  result?: RecipeResult;
  items: Map<string, ItemData>;
  /** Maps a craftable item's id to its recipe path -- see buildRecipeHrefMap. */
  recipeHrefs: Map<string, string>;
  ariaLabel: string;
}

const { cells, result, items, recipeHrefs, ariaLabel } = Astro.props;
const resultItem = result ? items.get(result.id) : undefined;
---

<div class="crafting">
  <div class="crafting__grid" role="img" aria-label={ariaLabel}>
    {
      cells.map((cell, index) => (
        <div class="crafting__cell" data-index={index}>
          {cell && (
            <ItemVariants
              items={cell.items}
              itemsMap={items}
              recipeHrefs={recipeHrefs}
              loading="eager"
            />
          )}
        </div>
      ))
    }
  </div>

  <div class="crafting__output">
    <div class="crafting__arrow" aria-hidden="true">→</div>

    <div class="crafting__result">
      <div class="crafting__cell">
        {
          resultItem && (
            <>
              <ItemIconTooltip
                item={resultItem}
                recipePath={recipeHrefs.get(resultItem.id) ?? null}
                loading="eager"
              />
              {result && result.count > 1 && <span class="crafting__count">×{result.count}</span>}
            </>
          )
        }
      </div>
    </div>
  </div>
</div>

<style>
  .crafting {
    --crafting-cell: 4rem;
    display: flex;
    /* Mobile: grid stacked above the arrow+result, always centered -- a
       fixed direction switch at the same breakpoint as --crafting-cell,
       not flex-wrap, so the layout never depends on guessing whether
       everything happens to fit on one line at a given viewport width. */
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    background-color: var(--color-panel);
    padding: calc(var(--space-4) + var(--panel-border-width));
    box-shadow: var(--bevel-panel), var(--panel-border-outer);
  }

  .crafting__grid {
    display: grid;
    grid-template-columns: repeat(3, var(--crafting-cell));
    grid-auto-rows: var(--crafting-cell);
    gap: var(--space-4);
  }

  .crafting__output {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .crafting__arrow {
    font-size: 1.5rem;
    color: var(--color-muted);
    flex-shrink: 0;
    /* Points down while the output sits below the grid on mobile; flipped
       back to pointing right once the layout goes side-by-side. */
    transform: rotate(90deg);
  }

  .crafting__result {
    width: var(--crafting-cell);
    flex-shrink: 0;
  }

  .crafting__cell {
    width: var(--crafting-cell);
    height: var(--crafting-cell);
    background-color: var(--color-slot);
    box-shadow: var(--bevel-slot);
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: var(--space-4);
  }

  .crafting__count {
    position: absolute;
    right: 0.15em;
    bottom: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-fg);
    text-shadow:
      1px 0 white,
      -1px 0 white,
      0 1px white,
      0 -1px white;
  }

  @media (min-width: 640px) {
    .crafting {
      --crafting-cell: 6rem;
      flex-direction: row;
      gap: var(--space-6);
    }

    .crafting__arrow {
      transform: none;
    }
  }
</style>
