---
import ItemIcon from './ItemIcon.astro';
import ItemStat from './ItemStat.astro';
import ItemVariants from './ItemVariants.astro';
import type { GridCell } from '../utils/crafting-grid';
import type { ItemData, RecipeResult } from '../content.config';

interface Props {
  cells: GridCell[];
  result?: RecipeResult;
  items: Map<string, ItemData>;
  ariaLabel: string;
}

const { cells, result, items, ariaLabel } = Astro.props;
const resultItem = result ? items.get(result.id) : undefined;
---

<div class="crafting">
  <div class="crafting__grid" role="img" aria-label={ariaLabel}>
    {
      cells.map((cell, index) => (
        <div class="crafting__cell" data-index={index}>
          {cell && <ItemVariants items={cell.items} itemsMap={items} loading="eager" />}
        </div>
      ))
    }
  </div>

  <div class="crafting__output">
    <div class="crafting__arrow" aria-hidden="true">→</div>

    <div class="crafting__result">
      <div class="crafting__cell">
        {
          resultItem && (
            <>
              <ItemIcon item={resultItem} loading="eager" />
              {result && result.count > 1 && <span class="crafting__count">×{result.count}</span>}
            </>
          )
        }
      </div>
      {resultItem?.stat && <ItemStat stat={resultItem.stat} />}
    </div>
  </div>
</div>

<style>
  .crafting {
    --crafting-cell: 4rem;
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background-color: var(--color-panel);
    padding: calc(var(--space-4) + var(--panel-border-width));
    box-shadow: var(--bevel-panel), var(--panel-border-outer);
    flex-wrap: wrap;
  }

  .crafting__grid {
    display: grid;
    grid-template-columns: repeat(3, var(--crafting-cell));
    grid-auto-rows: var(--crafting-cell);
    gap: var(--space-4);
  }

  .crafting__output {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .crafting__arrow {
    font-size: 1.5rem;
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .crafting__result {
    width: var(--crafting-cell);
    flex-shrink: 0;
  }

  .crafting__cell {
    width: var(--crafting-cell);
    height: var(--crafting-cell);
    background-color: var(--color-slot);
    box-shadow: var(--bevel-slot);
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: var(--space-4);
  }

  .crafting__count {
    position: absolute;
    right: 0.15em;
    bottom: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-fg);
    text-shadow:
      1px 0 white,
      -1px 0 white,
      0 1px white,
      0 -1px white;
  }

  @media (min-width: 640px) {
    .crafting {
      --crafting-cell: 6rem;
      gap: var(--space-6);
    }
  }
</style>
