---
import Badge from './Badge.astro';
import CraftingGrid from './CraftingGrid.astro';
import IngredientOptions from './IngredientOptions.astro';
import ItemCard from './ItemCard.astro';
import ItemIcon from './ItemIcon.astro';
import ItemStat from './ItemStat.astro';
import RecipeVariants from './RecipeVariants.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { buildShapedGrid, buildShapelessGrid, type GridCell } from '../utils/crafting-grid';
import { recipePath, type SiblingRecipe } from '../utils/recipe-groups';
import { ingredientOption, type IngredientOption } from '../utils/tag-label';
import { withBase } from '../utils/with-base';
import type { ItemData, RecipeData } from '../content.config';

interface Props {
  recipe: RecipeData;
  displayName: string;
  itemsMap: Map<string, ItemData>;
  /** Maps a craftable item's id to its recipe path -- see buildRecipeHrefMap. */
  recipeHrefs: Map<string, string>;
  /** This item's /recipe/{itemSlug}/... URL segment (see groupItemSlug). */
  itemSlug: string;
  /** The group's canonical recipe id -- reachable at the bare /recipe/{itemSlug}/ path, no slug segment. */
  canonicalId: string;
  siblings: SiblingRecipe[];
  prevHref: string;
  prevName: string;
  prevItem: ItemData | null;
  nextHref: string;
  nextName: string;
  nextItem: ItemData | null;
}

const {
  recipe,
  displayName,
  itemsMap,
  recipeHrefs,
  itemSlug,
  canonicalId,
  siblings,
  prevHref,
  prevName,
  prevItem,
  nextHref,
  nextName,
  nextItem,
} = Astro.props as Props;

const resultItem = recipe.result ? itemsMap.get(recipe.result.id) : undefined;
const getItemName = (id: string) => itemsMap.get(id)?.name ?? id;

const variants = siblings.map((sibling) => ({
  recipeId: sibling.recipeId,
  label: sibling.label,
  iconItem:
    (sibling.iconItemId ? itemsMap.get(sibling.iconItemId) : undefined) ?? resultItem ?? null,
  href: withBase(recipePath(itemSlug, canonicalId, sibling.recipeId, sibling.slug)),
}));

let cells: GridCell[] = [];
if (recipe.type === 'shaped' && recipe.pattern && recipe.key) {
  cells = buildShapedGrid(recipe.pattern, recipe.key);
} else if ((recipe.type === 'shapeless' || recipe.type === 'transmute') && recipe.ingredients) {
  cells = buildShapelessGrid(recipe.ingredients);
}

const hasGrid = recipe.type !== 'special';
const isShapeless = recipe.type === 'shapeless' || recipe.type === 'transmute';

const ingredientOptions: IngredientOption[] = [];
if (recipe.type === 'shaped' && recipe.key) {
  for (const ingredient of Object.values(recipe.key)) {
    const option = ingredientOption(ingredient, getItemName);
    if (option) ingredientOptions.push(option);
  }
} else if (recipe.ingredients) {
  for (const ingredient of recipe.ingredients) {
    const option = ingredientOption(ingredient, getItemName);
    if (option) ingredientOptions.push(option);
  }
}

const transmuteNote =
  recipe.type === 'transmute'
    ? "The result keeps the input item's contents/appearance."
    : undefined;

const ingredientNames = cells
  .filter((cell): cell is NonNullable<GridCell> => cell !== null)
  .map((cell) => getItemName(cell.items[0]));

const ariaLabel = `3 by 3 crafting grid for ${displayName}${
  ingredientNames.length > 0 ? `, using ${ingredientNames.join(', ')}` : ''
}`;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<MainLayout
  title={`${displayName} - Craftalog`}
  description={`How to craft ${displayName} in Minecraft.`}
>
  <div class="recipe">
    <div class="recipe__toolbar">
      <a href={withBase('/')} class="recipe__back link-chip">&larr; Back to all recipes</a>
      <button type="button" class="recipe__copy-link link-chip" data-url={canonicalUrl} hidden>
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
        <span class="recipe__copy-link-label">Copy link</span>
      </button>
    </div>

    <div class="recipe__header">
      <h1 class="recipe__title">{displayName}</h1>
      <div class="recipe__badges">
        {
          isShapeless && (
            <Badge variant="gui" title="Ingredient placement in the grid doesn't matter">
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M16 3h5v5" />
                <path d="M4 20 21 3" />
                <path d="M21 16v5h-5" />
                <path d="M15 15l6 6" />
                <path d="M4 4l5 5" />
              </svg>
              Shapeless
              <span class="visually-hidden">
                {' '}
                — ingredient placement in the grid doesn't matter
              </span>
            </Badge>
          )
        }
        <Badge>{recipe.family}</Badge>
        {recipe.type === 'transmute' && <Badge variant="gui">Transmute</Badge>}
      </div>
      {resultItem?.stat && <ItemStat stat={resultItem.stat} />}
    </div>

    {siblings.length > 1 && <RecipeVariants siblings={variants} currentId={recipe.id} />}

    {
      hasGrid ? (
        <>
          <CraftingGrid
            cells={cells}
            result={recipe.result}
            items={itemsMap}
            recipeHrefs={recipeHrefs}
            ariaLabel={ariaLabel}
          />

          <IngredientOptions
            entries={ingredientOptions}
            itemsMap={itemsMap}
            recipeHrefs={recipeHrefs}
            note={transmuteNote}
          />
        </>
      ) : (
        <div class="recipe__special">
          {resultItem && (
            <div class="recipe__special-icon">
              <ItemIcon item={resultItem} loading="eager" />
            </div>
          )}
          <p class="recipe__note">{recipe.note}</p>
        </div>
      )
    }

    <nav class="recipe__pager" aria-label="Recipe navigation">
      <ItemCard
        href={prevHref}
        item={prevItem}
        name={prevName}
        subtitle="Previous"
        subtitleFirst
        class="recipe__pager-link recipe__pager-link--prev"
      />
      <a href={withBase('/')} class="recipe__pager-home link-chip">All recipes</a>
      <ItemCard
        href={nextHref}
        item={nextItem}
        name={nextName}
        subtitle="Next"
        subtitleFirst
        class="recipe__pager-link recipe__pager-link--next"
      />
    </nav>
  </div>
</MainLayout>

<script>
  // astro:page-load fires on the initial load AND every subsequent View
  // Transitions navigation, so this re-binds correctly when navigating
  // between recipe pages via the client router.
  document.addEventListener('astro:page-load', () => {
    const button = document.querySelector<HTMLButtonElement>('.recipe__copy-link');
    const label = button?.querySelector<HTMLElement>('.recipe__copy-link-label');

    if (button && label) {
      const defaultLabel = label.textContent ?? 'Copy link';
      button.hidden = false;

      button.addEventListener('click', async () => {
        const url = button.dataset.url;
        if (!url) return;

        try {
          await navigator.clipboard.writeText(url);
          label.textContent = 'Copied';
          button.disabled = true;
          setTimeout(() => {
            label.textContent = defaultLabel;
            button.disabled = false;
          }, 1500);
        } catch {
          // Clipboard API unavailable or denied — the URL is still visible in the address bar.
        }
      });
    }
  });
</script>

<style>
  .recipe__toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    font-size: 0.8125rem;
  }

  .recipe__back {
    padding: var(--space-2) var(--space-4);
    color: var(--color-panel-fg);
  }

  .recipe__copy-link {
    flex-shrink: 0;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-panel-fg);
    cursor: pointer;
  }

  .recipe__copy-link:disabled {
    cursor: default;
  }

  .recipe__header {
    margin-bottom: var(--space-6);
  }

  .recipe__title {
    text-transform: capitalize;
  }

  .recipe__badges {
    margin-top: var(--space-3);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .recipe__note {
    margin-top: var(--space-4);
    max-width: 40rem;
    color: var(--color-muted);
  }

  .recipe__special {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background-color: var(--color-panel);
    padding: calc(var(--space-4) + var(--panel-border-width));
    box-shadow: var(--bevel-panel), var(--panel-border-outer);
  }

  .recipe__special-icon {
    width: 4rem;
    flex-shrink: 0;
  }

  .recipe__special .recipe__note {
    margin-top: 0;
    color: var(--color-panel-fg);
  }

  /* Mobile: prev/next share a row, "All recipes" sits centered below on its
     own row. Desktop (see media query): all three on one row, "All recipes"
     centered between prev and next. A fixed grid-template-areas switch, not
     flex-wrap, so this never depends on guessing what fits at a given width. */
  .recipe__pager {
    margin-top: var(--space-12);
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      'prev next'
      'home home';
    align-items: center;
    gap: var(--space-4);
    border-top: var(--divider-border);
    box-shadow: var(--divider-shadow-top);
    padding-top: var(--space-4);
    font-size: 0.875rem;
  }

  /* ItemCard renders its own <a> inside its own scoped style boundary, so a
     plain selector here would never match it -- :global() escapes that
     scoping to size/pad/place the card from the page that lays out the
     pager grid. */
  :global(.recipe__pager-link) {
    min-width: 0;
    max-width: 14rem;
    padding: var(--space-3) var(--space-4);
    gap: var(--space-2);
  }

  :global(.recipe__pager-link--prev) {
    grid-area: prev;
    justify-self: start;
  }

  :global(.recipe__pager-link--next) {
    grid-area: next;
    justify-self: end;
  }

  .recipe__pager-home {
    grid-area: home;
    justify-self: center;
    padding: var(--space-2) var(--space-4);
    color: var(--color-panel-fg);
  }

  @media (min-width: 640px) {
    .recipe__pager {
      grid-template-columns: 1fr auto 1fr;
      grid-template-areas: 'prev home next';
    }
  }
</style>
