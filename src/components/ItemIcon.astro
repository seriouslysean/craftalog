---
import { withBase } from '../utils/with-base';
import type { IconData } from '../content.config';

interface Props {
  item: {
    id: string;
    name: string;
    icon: IconData;
  } | null;
  /** Native lazy-loading hint for the underlying &lt;img&gt;. Defaults to lazy. */
  loading?: 'lazy' | 'eager';
}

interface Face {
  className: string;
  texture: string;
}

/** Builds the CSS-cube faces for a 3D icon. `block`/`slab` share the 3-face cube; `stairs` adds a stepped tread. */
function getFaces(icon: IconData): Face[] {
  if (icon.type === 'stairs') {
    return [
      { className: 'top-low', texture: icon.top },
      { className: 'top-high', texture: icon.top },
      { className: 'left-lower', texture: icon.side },
      { className: 'left-upper', texture: icon.side },
      { className: 'right', texture: icon.side },
      { className: 'riser', texture: icon.side },
    ];
  }

  if (icon.type === 'block' || icon.type === 'slab') {
    return [
      { className: 'top', texture: icon.top },
      { className: 'left', texture: icon.side },
      { className: 'right', texture: icon.side },
    ];
  }

  if (icon.type === 'pressure_plate' || icon.type === 'button') {
    return [
      { className: 'top', texture: icon.texture },
      { className: 'left', texture: icon.texture },
      { className: 'right', texture: icon.texture },
    ];
  }

  return [];
}

interface CompoundFaceStyle {
  outerTransform: string;
  content: { top: string; left: string; width: string; height: string };
}

/**
 * Positions one face of a "compound" icon's box element (real per-element
 * geometry from a block model, e.g. anvil's 4-element template_anvil parent
 * -- see scripts/lib/model.ts's extractCompoundElements). Formula validated
 * empirically (corner-marker probes matched the .top/.left/.right rules
 * above, pixel-for-pixel, for a full cube, a slab, and a pressure plate)
 * against this exact shared camera.
 *
 * All 6 directions are implemented. up/north/east are the only 3 faces a
 * SIMPLE CONVEX box ever shows from the compound camera (rotateX(-35deg)
 * rotateY(-135deg), matching vanilla's own GUI face selection -- see the
 * `.compound` rule below) -- but concave/hollow/stepped shapes (e.g. composter's
 * open-top hollow box, grindstone's post-and-wheel assembly) need
 * down/south/west too, for interior-facing surfaces this same fixed camera
 * genuinely exposes through a gap in the rest of the geometry. down and west
 * are a naive sign-flip mirror of up/east (opposite rotation direction,
 * anchored at the near-side coordinate instead of the far-side one) --
 * verified correct by matrix-tracing a local point through each transform's
 * exact function composition (not just assumed from symmetry). north is
 * NOT a naive sign-flip mirror of south: the same matrix trace shows
 * `rotateY(90deg) translateX(d) rotateY(-90deg)` (south's rotateY signs
 * both flipped) sends a local point to the WRONG side of the Z axis --
 * pixel-identical to south's own position rather than opposite it. The
 * correct north transform keeps south's rotateY(-90deg)...rotateY(-90deg)
 * pattern (same sign both times) and only swaps the anchor to the near-side
 * coordinate. This one only surfaced empirically: a naive-mirror first pass
 * still passed the solid-cube hidden-face check below (a full cube's
 * north/south content crops are symmetric enough that the bug doesn't
 * show), but rendering it against a real wide, thin element (oak_shelf's
 * shelf board) produced a second, disconnected copy of the board floating
 * outside the icon -- caught by adding a real, non-cubic element to the
 * validation sweep, not by the cube check alone.
 *
 * Validated three ways (originally under the pre-fix -45deg yaw; the same
 * depth-sorting argument holds unchanged at -135deg, re-verified visually
 * against dried_ghast/anvil/grindstone/composter after the camera fix):
 * (1) a full solid cube rendered with all 6 faces is
 * pixel-identical (bar sub-pixel edge AA) to one rendered with only
 * the 3 camera-facing faces -- the hidden faces stay fully behind the visible
 * ones for ordinary convex geometry, exactly like a real cube; (2)
 * composter's and grindstone's real element geometry, re-rendered with
 * every face their model JSON declares, closes the visible gaps that
 * 3-face rendering left (page background showing through the hollow
 * composter's back-right interior; a disconnected gap between grindstone's
 * support posts and its wheel); (3) every other affected item (anvil,
 * beacon, lectern, stonecutter, chiseled_bookshelf, carpets, trapdoors,
 * shelves) re-renders with no new gaps or floating geometry.
 *
 * Returns a TWO-LEVEL style on purpose. Cropping a transformed element's own
 * box natively (top/left/width/height set on the SAME element that also
 * carries the depth transform) shifts its rotation origin and silently
 * corrupts the depth placement -- confirmed while deriving this formula.
 * `outerTransform` goes on a full 100%x100% element (correct, unshifted
 * rotation origin); `content` goes on a plain, non-transformed child (crop +
 * texture), inheriting the outer's already-correct 3D placement for free.
 */
const pct = (n: number) => `${(n * 100).toFixed(4)}%`;

function computeFaceStyle(
  from: [number, number, number],
  to: [number, number, number],
  face: 'up' | 'down' | 'north' | 'south' | 'east' | 'west',
): CompoundFaceStyle {
  const nx0 = from[0] / 16;
  const nx1 = to[0] / 16;
  const ny0 = from[1] / 16;
  const ny1 = to[1] / 16;
  const nz0 = from[2] / 16;
  const nz1 = to[2] / 16;

  if (face === 'up') {
    const ty = -(ny1 - 0.5) * 100;
    return {
      outerTransform: `translateY(${ty.toFixed(4)}%) rotateX(90deg) var(--face-overlap)`,
      content: { top: pct(nz0), left: pct(nx0), width: pct(nx1 - nx0), height: pct(nz1 - nz0) },
    };
  }

  if (face === 'down') {
    const ty = -(ny0 - 0.5) * 100;
    return {
      outerTransform: `translateY(${ty.toFixed(4)}%) rotateX(-90deg) var(--face-overlap)`,
      content: {
        top: pct(1 - nz1),
        left: pct(nx0),
        width: pct(nx1 - nx0),
        height: pct(nz1 - nz0),
      },
    };
  }

  if (face === 'east') {
    const d = (nx1 - 0.5) * 100;
    return {
      outerTransform: `translateX(${d.toFixed(4)}%) rotateY(90deg) var(--face-overlap)`,
      content: {
        top: pct(1 - ny1),
        left: pct(1 - nz1),
        width: pct(nz1 - nz0),
        height: pct(ny1 - ny0),
      },
    };
  }

  if (face === 'west') {
    const d = (nx0 - 0.5) * 100;
    return {
      outerTransform: `translateX(${d.toFixed(4)}%) rotateY(-90deg) var(--face-overlap)`,
      content: { top: pct(1 - ny1), left: pct(nz0), width: pct(nz1 - nz0), height: pct(ny1 - ny0) },
    };
  }

  if (face === 'south') {
    const d = (nz1 - 0.5) * 100;
    return {
      outerTransform: `rotateY(-90deg) translateX(${d.toFixed(4)}%) rotateY(90deg) var(--face-overlap)`,
      content: { top: pct(1 - ny1), left: pct(nx0), width: pct(nx1 - nx0), height: pct(ny1 - ny0) },
    };
  }

  // north
  const d = (nz0 - 0.5) * 100;
  return {
    outerTransform: `rotateY(-90deg) translateX(${d.toFixed(4)}%) rotateY(-90deg) var(--face-overlap)`,
    content: {
      top: pct(1 - ny1),
      left: pct(1 - nx1),
      width: pct(nx1 - nx0),
      height: pct(ny1 - ny0),
    },
  };
}

interface UvCrop {
  /** `background-size`/`background-position` for `.compound__face-content`'s own `background-image` (see this function's comment for why it's a background-image, not a child `<img>`). */
  background: { size: string; position: string };
  /** Applied to the crop container itself. See this function's own comment for why. */
  contentTransform: string;
}

/**
 * Computes the `background-size`/`background-position` needed to crop a
 * compound face's full 16x16 source texture down to just its declared `uv`
 * sub-rectangle ([u0,v0,u1,v1], 0-16 texture-pixel space -- Minecraft's UV
 * convention; see scripts/lib/model.ts's extractCompoundElements/
 * defaultFaceUv, which produce this rect).
 *
 * This is a `background-image` on `.compound__face-content` itself -- same
 * mechanism this file already uses for wall/fence/fence-gate faces -- NOT
 * an oversized, offset child `<img>` clipped via `overflow: hidden`. That
 * was the first implementation and it's wrong: empirically confirmed (see
 * PR discussion / commit history around this fix) that `overflow: hidden`
 * on many `.compound__face-content` siblings inside this `preserve-3d`
 * stack, on a real content-heavy page, causes Chromium's compositor to
 * "squash" some of those clipped layers into a shared 2D-painted backing
 * layer -- silently flattening that face's true 3D interleaving into a
 * flat, undistorted card. Reproducible deterministically on a real recipe
 * page; does NOT reproduce with the exact same markup in isolation (no
 * other page content) -- a compositing-budget effect, not a logic bug in
 * this formula or computeFaceStyle. `clip-path: inset(0)` as a drop-in
 * `overflow: hidden` replacement does not fix it either. Switching to
 * `background-image` (no clipping element at all -- backgrounds never
 * overflow their box) does, verified pixel-stable across repeated reloads.
 *
 * `u0 > u1` (or `v0 > v1`) signals the source should be mirrored on that
 * axis for this face -- e.g. grindstone leg element 0's east face
 * (uv: [10, 16, 6, 9], both axes flipped). The mirror is applied to the
 * CROP CONTAINER itself (`.compound__face-content`), not the background
 * image: the container's own box is already sized/positioned to exactly
 * the visible viewport, so a CSS `scale(-1, ...)` about its default center
 * transform-origin reverses display order within that same rectangle for
 * free.
 */
function computeUvCrop([u0, v0, u1, v1]: [number, number, number, number]): UvCrop {
  const fu = Math.min(u0, u1);
  const fv = Math.min(v0, v1);
  // Guard a degenerate zero-width/height rect (shouldn't occur in real
  // model data) rather than dividing by zero.
  const w = Math.abs(u1 - u0) || 16;
  const h = Math.abs(v1 - v0) || 16;
  const flipX = u0 > u1 ? -1 : 1;
  const flipY = v0 > v1 ? -1 : 1;

  // background-size is the same oversized-image scale as before (16/w,
  // 16/h). background-position is a percentage of (bgSize - container),
  // not of container like top/left -- convert: at bgSize == container
  // (w or h == 16) that denominator is 0, so position is a no-op 0%.
  const posX = w === 16 ? 0 : (-100 * fu) / (w - 16);
  const posY = h === 16 ? 0 : (-100 * fv) / (h - 16);

  return {
    background: {
      size: `${pct(16 / w)} ${pct(16 / h)}`,
      position: `${posX.toFixed(4)}% ${posY.toFixed(4)}%`,
    },
    contentTransform: `scale(${flipX}, ${flipY})`,
  };
}

interface CompoundFacePart {
  key: string;
  outerTransform: string;
  content: { top: string; left: string; width: string; height: string; transform: string };
  background: { size: string; position: string };
  texture: string;
}

/** Flattens a compound icon's elements into one render-ready face list (each element contributes up to 6: up/down/north/south/east/west, whichever the model data actually declares). */
function getCompoundFaces(icon: IconData): CompoundFacePart[] {
  if (icon.type !== 'compound') return [];

  const parts: CompoundFacePart[] = [];
  icon.elements.forEach((el, elIndex) => {
    (['up', 'down', 'north', 'south', 'east', 'west'] as const).forEach((face) => {
      const faceData = el.faces[face];
      if (!faceData) return;
      const style = computeFaceStyle(el.from, el.to, face);
      const crop = computeUvCrop(faceData.uv);
      parts.push({
        key: `${elIndex}-${face}`,
        outerTransform: style.outerTransform,
        content: { ...style.content, transform: crop.contentTransform },
        background: crop.background,
        texture: withBase(faceData.texture),
      });
    });
  });
  return parts;
}

/** Fence gate's 8 elements (2 outer posts, 2 inner door posts, 4 door bars) all
 * share the same Z-depth band (block-space z:7-9, centered), so -- unlike
 * fence's posts -- none of these need the group-level depth-shift trick;
 * each is just its own X/Y-cropped box, keyed by CSS class below. */
const FENCE_GATE_PARTS = [
  'post-outer-left',
  'post-outer-right',
  'post-inner-left',
  'post-inner-right',
  'bar-lower-left',
  'bar-upper-left',
  'bar-lower-right',
  'bar-upper-right',
];

const { item, loading = 'lazy' } = Astro.props;
const is3d =
  item?.icon.type === 'block' ||
  item?.icon.type === 'slab' ||
  item?.icon.type === 'stairs' ||
  item?.icon.type === 'pressure_plate' ||
  item?.icon.type === 'button' ||
  item?.icon.type === 'wall' ||
  item?.icon.type === 'fence' ||
  item?.icon.type === 'fence_gate' ||
  item?.icon.type === 'compound';
const faces = item ? getFaces(item.icon) : [];
const compoundFaces = item ? getCompoundFaces(item.icon) : [];
const compoundYRotation = item && item.icon.type === 'compound' ? item.icon.yRotation : 0;
// Wall/fence/fence_gate are multi-element compounds (a center post + a wider
// cross-brace; 2 corner posts + 2 connecting bars; 8 posts/bars) rather than
// "one box, different faces" -- every element shares the same single
// texture, resolved once here for the multi-group markup below.
const wallTexture = item && item.icon.type === 'wall' ? withBase(item.icon.texture) : '';
const fenceTexture = item && item.icon.type === 'fence' ? withBase(item.icon.texture) : '';
const fenceGateTexture = item && item.icon.type === 'fence_gate' ? withBase(item.icon.texture) : '';
---

{
  item && (
    <div
      class:list={[
        'item-icon',
        {
          // Two camera families, two --icon-scale/max-width pairs (see the
          // derivation above .item-icon--block below) -- fence_gate runs its
          // own shallower 30deg-pitch camera, every other 3D type shares the
          // 35deg-pitch camera.
          'item-icon--block': is3d && item.icon.type !== 'fence_gate',
          'item-icon--fence-gate': item.icon.type === 'fence_gate',
        },
      ]}
    >
      {item.icon.type === 'flat' ? (
        <img
          class="icon"
          src={withBase(item.icon.texture)}
          alt={item.name}
          title={item.name}
          width="16"
          height="16"
          loading={loading}
          decoding="async"
        />
      ) : item.icon.type === 'wall' ? (
        <div class="wall" role="img" aria-label={item.name} title={item.name}>
          {['post', 'base'].map((part) => (
            <div class:list={['wall__group', `wall__group--${part}`]}>
              <div class="wall__top" style={`background-image: url(${wallTexture})`} />
              <div
                class="wall__side wall__side--east"
                style={`background-image: url(${wallTexture})`}
              />
              <div
                class="wall__side wall__side--south"
                style={`background-image: url(${wallTexture})`}
              />
            </div>
          ))}
        </div>
      ) : item.icon.type === 'fence' ? (
        <div class="fence" role="img" aria-label={item.name} title={item.name}>
          {['left', 'right'].map((side) => (
            <div class:list={['fence__post', `fence__post--${side}`]}>
              <div class="fence__post-top" style={`background-image: url(${fenceTexture})`} />
              <div
                class="fence__post-side fence__post-side--east"
                style={`background-image: url(${fenceTexture})`}
              />
              <div
                class="fence__post-side fence__post-side--south"
                style={`background-image: url(${fenceTexture})`}
              />
            </div>
          ))}
          {['upper', 'lower'].map((position) => (
            <div class:list={['fence__bar', `fence__bar--${position}`]}>
              <div class="fence__bar-top" style={`background-image: url(${fenceTexture})`} />
              <div
                class="fence__bar-side fence__bar-side--east"
                style={`background-image: url(${fenceTexture})`}
              />
              <div
                class="fence__bar-side fence__bar-side--south"
                style={`background-image: url(${fenceTexture})`}
              />
            </div>
          ))}
        </div>
      ) : item.icon.type === 'fence_gate' ? (
        <div class="fence-gate" role="img" aria-label={item.name} title={item.name}>
          {FENCE_GATE_PARTS.map((part) => (
            <div class:list={['fence-gate__el', `fence-gate__el--${part}`]}>
              <div class="fence-gate__top" style={`background-image: url(${fenceGateTexture})`} />
              <div
                class="fence-gate__side fence-gate__side--west"
                style={`background-image: url(${fenceGateTexture})`}
              />
              <div
                class="fence-gate__side fence-gate__side--south"
                style={`background-image: url(${fenceGateTexture})`}
              />
            </div>
          ))}
        </div>
      ) : item.icon.type === 'compound' ? (
        <ul
          class="compound"
          style={`--compound-y-rotation: ${compoundYRotation}deg`}
          role="img"
          aria-label={item.name}
          title={item.name}
        >
          {compoundFaces.map((face) => (
            <li class="compound__face" style={`transform: ${face.outerTransform}`}>
              <div
                class="compound__face-content"
                style={`top: ${face.content.top}; left: ${face.content.left}; width: ${face.content.width}; height: ${face.content.height}; transform: ${face.content.transform}; background-image: url(${face.texture}); background-size: ${face.background.size}; background-position: ${face.background.position};`}
              />
            </li>
          ))}
        </ul>
      ) : (
        <ul
          class:list={[
            'block',
            {
              'block--slab': item.icon.type === 'slab',
              'block--stairs': item.icon.type === 'stairs',
              'block--pressure-plate': item.icon.type === 'pressure_plate',
              'block--button': item.icon.type === 'button',
            },
          ]}
          role="img"
          aria-label={item.name}
          title={item.name}
        >
          {faces.map((face) => (
            <li class={face.className}>
              <img
                src={withBase(face.texture)}
                alt=""
                width="16"
                height="16"
                loading={loading}
                decoding="async"
              />
            </li>
          ))}
        </ul>
      )}
    </div>
  )
}

<style>
  .item-icon {
    width: 100%;
    position: relative;
    aspect-ratio: 1/1;
    image-rendering: pixelated;
    /* Every 3D engine below (.block/.wall/.fence/.fence-gate/.compound)
       positions its faces by percentage against a local 0-100% reference
       cube, then views it through a fixed rotateX/rotateY camera with NO
       `perspective` set anywhere in this file -- i.e. a true orthographic
       projection. Orthographically, a unit cube rotated by pitch φ then yaw
       θ (`rotateX(φ) rotateY(θ)`) projects to a screen-space footprint of
       |cosθ|+|sinθ| wide by |sinφ|(|sinθ|+|cosθ|)+|cosφ| tall, in multiples
       of the cube's own edge (extrema land on the 8 corners for any affine
       map of a box). At this file's 35deg/45-or-135deg camera that's
       1.4142 x 1.6303 -- i.e. the reference cube ALWAYS overflows a 1x1 box
       by ~63% in height, for every 3D icon type, not just compound ones.
       This went unnoticed for cube-ish shapes (anvil, dirt, a wall) because
       the bleed is symmetric on all 4 sides and was absorbed into the old
       `max-width: 60%` whitespace margin below -- it only became visibly
       broken for compound elements whose REAL geometry is flat/thin
       (carpets height 1, snow height 2, trapdoors height 3, all out of 16):
       the same 63% bleed concentrates entirely at the bottom edge instead of
       spreading evenly, and pokes out of the box for real (most visibly the
       item-hover tooltip's bordered card).

       Fix: `--icon-scale` below (one constant per camera family -- see
       `.item-icon--block`/`.item-icon--fence-gate`) is the exact reciprocal
       of that projected height, prepended as `scale3d(...)` to each engine's
       OWN top-level transform (`.block`/`.wall`/`.fence`/`.fence-gate`/
       `.compound`). A uniform scale3d commutes with rotation and, applied on
       the element that establishes a `preserve-3d` stack's shared 3D frame,
       factors through every descendant's own transform untouched (matrix
       algebra: parent's `kI * Rx * Ry` times any child's local matrix always
       reduces to `k * (that child's original placement)`) -- so this needed
       zero changes to computeFaceStyle, computeUvCrop, --face-overlap, or
       any hand-authored per-face percentage anywhere below. `max-width`
       grows by the same factor so already-shipped icons keep the exact same
       on-screen size (the two changes are reciprocal by construction: old
       content size = 0.6 * 1.6303 in cell-units; new content size =
       (0.6 * 1.6303) * (1/1.6303), identical, just now bounded by the box's
       own edge instead of by luck). Only now the box's edge genuinely is
       the icon's edge, so `overflow: hidden` below is a real backstop (the
       sub-1% fringe `--face-overlap` itself adds) rather than a crop of
       real content. This is the single shared wrapper for every icon
       type/context sitewide, and sits outside every engine's own
       `preserve-3d` stack -- clipping here is a plain 2D box crop, not the
       per-face `overflow: hidden` that caused compositor squashing (see
       computeUvCrop's docstring); safe to contain unconditionally. */
    overflow: hidden;
  }

  .item-icon--block {
    /* 1 / 1.6303 (see .item-icon's comment) -- the 35deg-pitch camera shared
       by .block/.wall/.fence/.compound (45deg and 135deg yaw have identical
       |cos|/|sin| magnitudes, so both cameras project to the same extent). */
    --icon-scale: 0.6134;
    max-width: 97.8155%;
    margin-inline: auto;
    /* Adjacent 3D faces that share a mathematically exact edge still rasterize
       with a hairline background gap (sub-pixel anti-aliasing). Appending this
       to a face's transform (i.e. applied first, in the face's own flat plane)
       overgrows every edge ~1.5% so neighboring faces overlap instead of abut. */
    --face-overlap: scale(1.03);
  }

  .item-icon--fence-gate {
    /* 1 / 1.5731 (see .item-icon's comment) -- fence-gate's own shallower
       30deg-pitch camera (vanilla's GUI pitch for this model) projects a
       shorter 1.5731 height, not .item-icon--block's 1.6303. */
    --icon-scale: 0.6357;
    max-width: 94.3879%;
    margin-inline: auto;
    --face-overlap: scale(1.03);
  }

  .icon {
    width: 100%;
    height: 100%;
    /* Every flat texture is a square 16x16 except banners (20x40) --
       object-fit: contain scales those down to fit the square slot instead
       of overflowing it, and is a no-op for the square case. */
    object-fit: contain;
  }

  .block {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transform: scale3d(var(--icon-scale), var(--icon-scale), var(--icon-scale)) rotateX(-35deg)
      rotateY(-45deg);
  }

  .block .top,
  .block .left,
  .block .right,
  .block .top-low,
  .block .top-high,
  .block .left-lower,
  .block .left-upper,
  .block .riser {
    background-color: #fff;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
  }

  .block img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .left,
  .left-lower,
  .left-upper {
    transform: rotateY(-90deg) translateX(50%) rotateY(90deg);
  }

  .right {
    transform: translateX(50%) rotateY(90deg);
  }

  .top {
    transform: translateY(-50%) rotateX(90deg);
  }

  /* Slab: half-height box — top face drops to the container's mid-line, sides keep only their bottom half. */
  .block--slab .top {
    transform: rotateX(90deg);
  }

  .block--slab .left,
  .block--slab .right {
    top: 50%;
    height: 50%;
  }

  /* Stairs: the low tread faces the viewer (near corner), rising to a full-height back half. */
  .block--stairs .top-low {
    width: 50%;
    left: 50%;
    transform: rotateX(90deg);
  }

  .block--stairs .top-high {
    width: 50%;
    left: 0;
    transform: translateY(-50%) rotateX(90deg);
  }

  .block--stairs .left-lower {
