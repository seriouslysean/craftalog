---
import { withBase } from '../utils/with-base';
import type { IconData } from '../content.config';

interface Props {
  item: {
    id: string;
    name: string;
    icon: IconData;
  } | null;
  /** Native lazy-loading hint for the underlying <img>. Defaults to lazy. */
  loading?: 'lazy' | 'eager';
}

const { item, loading = 'lazy' } = Astro.props;
const isBlock = item?.icon.type === 'block';
---

{
  item && (
    <div class:list={['item-icon', { 'item-icon--block': isBlock }]}>
      {item.icon.type === 'block' ? (
        <ul class="block" role="img" aria-label={item.name} title={item.name}>
          <li class="top">
            <img
              src={withBase(item.icon.top)}
              alt=""
              width="16"
              height="16"
              loading={loading}
              decoding="async"
            />
          </li>
          <li class="left">
            <img
              src={withBase(item.icon.side)}
              alt=""
              width="16"
              height="16"
              loading={loading}
              decoding="async"
            />
          </li>
          <li class="right">
            <img
              src={withBase(item.icon.side)}
              alt=""
              width="16"
              height="16"
              loading={loading}
              decoding="async"
            />
          </li>
        </ul>
      ) : (
        <img
          class="icon"
          src={withBase(item.icon.texture)}
          alt={item.name}
          title={item.name}
          width="16"
          height="16"
          loading={loading}
          decoding="async"
        />
      )}
    </div>
  )
}

<style>
  .item-icon {
    width: 100%;
    position: relative;
    aspect-ratio: 1/1;
    image-rendering: pixelated;
  }

  .item-icon--block {
    max-width: 60%;
    margin-inline: auto;
  }

  .icon {
    width: 100%;
    height: auto;
    background-color: var(--color-slot);
  }

  .block {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transform: rotateX(-35deg) rotateY(-45deg);
  }

  .block .top,
  .block .left,
  .block .right {
    background-color: #fff;
    width: 100%;
    height: 100%;
    position: absolute;
    display: flex;
  }

  .block img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .left {
    transform: rotateY(-90deg) translateX(50%) rotateY(90deg);
  }

  .right {
    transform: translateX(50%) rotateY(90deg);
  }

  .top {
    transform: translateY(-50%) rotateX(90deg);
  }
</style>
