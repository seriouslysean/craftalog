---
import { withBase } from '../utils/with-base';

const currentPath = Astro.url.pathname;

// Helper to check if a link is active
const isActive = (path: string) => {
  const fullPath = withBase(path);
  return currentPath === fullPath || currentPath === `${fullPath}/`;
};
---

<header>
  <div class="header-content">
    <a href={withBase('/')} class="logo">Craftalog</a>

    <nav class="nav">
      <ul>
        <li>
          <a href={withBase('/')} class:list={[{ active: isActive('/') }]}>Home</a>
        </li>
        <li>
          <a href={withBase('/about')} class:list={[{ active: isActive('/about') }]}>About</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: var(--border-width) solid var(--color-gray-dark);
  }

  .header-content {
    max-width: 60rem;
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .header-content {
      padding-left: var(--space-8);
      padding-right: var(--space-8);
    }
  }

  .logo {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 400;
    letter-spacing: 0;
    border: none;
  }

  .logo:hover {
    border: none;
    opacity: 0.7;
  }

  .nav ul {
    display: flex;
    gap: var(--space-1);
    margin: 0;
  }

  .nav li {
    list-style: none;
  }

  .nav a {
    padding: var(--space-1) var(--space-2);
    font-size: 0.9375rem;
    color: var(--color-muted);
    border: none;
    transition: all 0.15s;
  }

  .nav a:hover,
  .nav a.active {
    background-color: var(--color-panel);
    color: var(--color-panel-fg);
    box-shadow: var(--bevel-raised);
    border: none;
  }

  .nav a.active {
    font-weight: 500;
  }
</style>
