---
import '@fontsource/pixelify-sans/latin-500.css';
import '@fontsource/pixelify-sans/latin-700.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Craftalog is a Minecraft recipe catalog. Find the recipe you need quickly and easily!',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import 'modern-normalize/modern-normalize.css';

  :root {
    /* Minecraft colors */
    --color-gray: #8b8b8b;
    --color-gray-light: #c6c6c6;
    --color-gray-dark: #373737;

    /* The whole site sits on the same light gray as the game's own GUI
       screens (verified against the real Java Edition palette:
       #ffffff/#c6c6c6/#8b8b8b/#555555/#373737/#000000), not a separate
       "clean" white backdrop. */
    --color-bg: var(--color-gray-light);
    --color-fg: #09090b;
    --color-border: #e4e4e7;
    --color-muted: #3f3f46;
    /* Minecraft hardcodes its container GUI title text (e.g. "Inventory",
       "Crafting Table") to exactly this dark gray. */
    --color-heading: #404040;

    /* Minecraft GUI system: panels/slots for recipe-mechanical surfaces
       (crafting grid, ingredient options). */
    --color-panel: var(--color-gray-light);
    --color-panel-fg: var(--color-gray-dark);
    --color-slot: var(--color-gray);

    /* The Minecraft inset/outset bevel: a background color plus two
       translucent box-shadows -- one dark, one light -- offset diagonally so
       each shows up as a solid pip of color in opposite corners. --bevel-slot
       is the recessed look for crafting/ingredient item slots; --bevel-button
       is the exact same colors and offset with the corners flipped, for a
       raised/clickable look. Both stay off border-radius -- the alpha shadow
       clipped by a curved corner reads as a smudgy gradient, not a clean
       stamped edge. */
    --bevel-slot:
      0.5em 0.5em 0 0 rgba(0, 0, 0, 0.5) inset, -0.5em -0.5em 0 0 rgba(255, 255, 255, 0.75) inset;
    --bevel-button:
      -0.5em -0.5em 0 0 rgba(0, 0, 0, 0.5) inset, 0.5em 0.5em 0 0 rgba(255, 255, 255, 0.75) inset;
    --bevel-button-pressed:
      0.5em 0.5em 0 0 rgba(0, 0, 0, 0.5) inset, -0.5em -0.5em 0 0 rgba(255, 255, 255, 0.75) inset;

    /* Shape */
    --radius-sm: 0.375rem;
    --radius-md: 0.5rem;
    --radius-pill: 999px;

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;

    /* Typography */
    --font-sans:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
    /* Pixel display font matching the game's own thin-stroke UI font, reserved
       for headings/wordmark only -- body copy and dense catalog text stay on
       --font-sans so long/frequent strings stay scannable. */
    --font-display: 'Pixelify Sans', var(--font-mono);
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-fg);
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  figure,
  p,
  ol,
  ul {
    margin: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: 0;
    color: var(--color-heading);
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-top: var(--space-8);
    color: var(--color-heading);
  }

  h2:first-child {
    margin-top: 0;
  }

  ol,
  ul {
    list-style: none;
    padding-inline: 0;
  }

  a {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.2s;
  }

  a:hover {
    border-bottom-color: var(--color-fg);
  }

  img {
    display: block;
    max-inline-size: 100%;
  }

  /* Shared "button" look -- copy-link, pager links, catalog cards, and
     category pills all use exactly this, so the whole site has one
     clickable-control style instead of a different one per component. Same
     raised bevel as the crafting grid's slots, just inverted, and square for
     the same reason the grid is square (see --bevel-button above). */
  .link-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    background-color: var(--color-panel);
    box-shadow: var(--bevel-button);
  }

  .link-chip:hover,
  .link-chip:active,
  .link-chip--selected {
    box-shadow: var(--bevel-button-pressed);
  }

  .link-chip:active {
    transform: translate(1px, 1px);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
</style>
