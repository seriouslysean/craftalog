---
import '@fontsource/silkscreen/latin-400.css';
import '@fontsource/silkscreen/latin-700.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Craftalog is a Minecraft recipe catalog. Find the recipe you need quickly and easily!',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import 'modern-normalize/modern-normalize.css';

  :root {
    /* Minecraft colors */
    --color-gray: #8b8b8b;
    --color-gray-light: #c6c6c6;
    --color-gray-dark: #373737;

    /* Site chrome commits to the same Minecraft GUI-screen gray as the crafting
       panel, rather than sitting on a separate "clean" white backdrop -- the
       whole page reads as one workbench, not two competing visual languages.
       No surface in this UI is ever plain white -- every fill comes from this
       gray trio (light panel / mid slot / dark border-and-text), same as the
       real game's inventory and settings screens. */
    --color-bg: var(--color-gray-light);
    --color-fg: #09090b;
    --color-border: #e4e4e7;
    --color-muted: #3f3f46;

    /* Minecraft GUI system: panels/slots for recipe-mechanical surfaces
       (crafting grid, ingredient options). */
    --color-panel: var(--color-gray-light);
    --color-panel-fg: var(--color-gray-dark);
    --color-slot: var(--color-gray);

    /* Hard, solid two-tone pixel borders -- no alpha, no blur, no curves. Same
       "no blending" logic as image-rendering: pixelated on the item icons:
       raised = light top/left + dark bottom/right; sunken (pressed/recessed)
       reverses it. Both tones come straight from the grid's own gray palette
       (light panel / dark border) rather than white, so buttons read as the
       same material as the crafting slots. Consumed via `border-color`;
       `border-width`/`-style` set per component alongside it. */
    --pixel-light: var(--color-gray-light);
    --pixel-dark: var(--color-gray-dark);
    --pixel-border-raised: var(--pixel-light) var(--pixel-dark) var(--pixel-dark) var(--pixel-light);
    --pixel-border-sunken: var(--pixel-dark) var(--pixel-light) var(--pixel-light) var(--pixel-dark);

    /* Shape: hard, square corners everywhere -- Minecraft's UI has no rounded edges */
    --radius-sm: 0;
    --radius-md: 0;

    /* Chunky pixel-UI borders: -sm for small chips/badges, base for panels/buttons/inputs */
    --border-width-sm: 0.125rem;
    --border-width: 0.1875rem;

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;

    /* Typography */
    --font-sans:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
    /* Chunky pixel display font, reserved for headings/wordmark only -- body copy and
       dense catalog text stay on --font-sans so long/frequent strings stay scannable. */
    --font-display: 'Silkscreen', var(--font-mono);
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-fg);
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  figure,
  p,
  ol,
  ul {
    margin: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: 0;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-top: var(--space-8);
  }

  h2:first-child {
    margin-top: 0;
  }

  ol,
  ul {
    list-style: none;
    padding-inline: 0;
  }

  a {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.2s;
  }

  a:hover {
    border-bottom-color: var(--color-fg);
  }

  img {
    display: block;
    max-inline-size: 100%;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
</style>
