---
import '@fontsource/pixelify-sans/latin-500.css';
import '@fontsource/pixelify-sans/latin-700.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Craftalog is a Minecraft recipe catalog. Find the recipe you need quickly and easily!',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import 'modern-normalize/modern-normalize.css';

  :root {
    /* Minecraft colors */
    --color-gray: #8b8b8b;
    --color-gray-light: #c6c6c6;
    --color-gray-dark: #373737;

    /* Site chrome commits to the same Minecraft GUI-screen gray as the crafting
       panel, rather than sitting on a separate "clean" white backdrop -- the
       whole page reads as one workbench, not two competing visual languages.
       No surface in this UI is ever plain white -- every fill comes from this
       gray trio (light panel / mid slot / dark border-and-text), same as the
       real game's inventory and settings screens. */
    --color-bg: var(--color-gray-light);
    --color-fg: #09090b;
    --color-border: #e4e4e7;
    --color-muted: #3f3f46;

    /* Minecraft GUI system: panels/slots for recipe-mechanical surfaces
       (crafting grid, ingredient options). */
    --color-panel: var(--color-gray-light);
    --color-panel-fg: var(--color-gray-dark);
    --color-slot: var(--color-gray);

    /* Thick, high-contrast diagonal bevel -- the real Minecraft inset/outset
       slot effect, same size and colors in both directions: only which
       corner gets which color flips. sunken = dark top-left / light
       bottom-right (recessed crafting/ingredient slots, inputs); raised =
       inverted (buttons, embossed). Deliberately NOT paired with
       border-radius anywhere it's used -- an alpha shadow clipped by a
       curved corner reads as a smudgy gradient instead of a clean
       punched/stamped edge, which is why --radius-sm/--radius-md stay at 0
       site-wide. */
    --bevel-highlight: rgba(255, 255, 255, 0.75);
    --bevel-shadow: rgba(0, 0, 0, 0.5);
    --bevel-sunken:
      0.5em 0.5em 0 0 var(--bevel-shadow) inset, -0.5em -0.5em 0 0 var(--bevel-highlight) inset;
    --bevel-raised:
      -0.5em -0.5em 0 0 var(--bevel-shadow) inset, 0.5em 0.5em 0 0 var(--bevel-highlight) inset;

    /* Shape: hard, square corners everywhere -- Minecraft's UI has no rounded edges */
    --radius-sm: 0;
    --radius-md: 0;

    /* Flat single-tone borders, for surfaces that don't use the bevel above:
       -sm is the thin badge/card outline; base is the bolder structural
       frame (panel edges, header/footer divider). */
    --border-width-sm: 0.0625rem;
    --border-width: 0.125rem;

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;

    /* Typography */
    --font-sans:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    --font-mono: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
    /* Pixel display font matching the game's own thin-stroke UI font, reserved
       for headings/wordmark only -- body copy and dense catalog text stay on
       --font-sans so long/frequent strings stay scannable. */
    --font-display: 'Pixelify Sans', var(--font-mono);
  }

  * {
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-fg);
    line-height: 1.6;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  figure,
  p,
  ol,
  ul {
    margin: 0;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: 0;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-top: var(--space-8);
  }

  h2:first-child {
    margin-top: 0;
  }

  ol,
  ul {
    list-style: none;
    padding-inline: 0;
  }

  a {
    color: var(--color-fg);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: border-color 0.2s;
  }

  a:hover {
    border-bottom-color: var(--color-fg);
  }

  img {
    display: block;
    max-inline-size: 100%;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
</style>
