---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import ItemIcon from '../components/ItemIcon.astro';
import { withBase } from '../utils/with-base';
import { recipeSubtitle } from '../utils/recipe-subtitle';
import meta from '../data/generated/meta.json';

const recipeEntries = await getCollection('recipes');
const itemEntries = await getCollection('items');
const itemsMap = new Map(itemEntries.map((entry) => [entry.id, entry.data]));
const getItemName = (id: string) => itemsMap.get(id)?.name ?? id;

const CATEGORY_ORDER = ['building', 'equipment', 'redstone', 'misc'];
const CATEGORY_LABELS: Record<string, string> = {
  building: 'Building Blocks',
  equipment: 'Tools & Equipment',
  redstone: 'Redstone',
  misc: 'Miscellaneous',
};

const categories = [
  ...CATEGORY_ORDER,
  ...new Set(
    recipeEntries.map((entry) => entry.data.category).filter((c) => !CATEGORY_ORDER.includes(c)),
  ),
];

const resultCounts = new Map<string, number>();
for (const entry of recipeEntries) {
  const resultId = entry.data.result?.id;
  if (resultId) resultCounts.set(resultId, (resultCounts.get(resultId) ?? 0) + 1);
}

const sections = categories
  .map((category) => {
    const entries = recipeEntries
      .filter((entry) => entry.data.category === category)
      .map((entry) => {
        const resultId = entry.data.result?.id;
        const resultItem = resultId ? itemsMap.get(resultId) : undefined;
        const name = resultItem?.name ?? entry.data.id.replace(/_/g, ' ');
        const subtitle =
          resultId && (resultCounts.get(resultId) ?? 0) > 1
            ? recipeSubtitle(entry.data, getItemName)
            : null;
        return { id: entry.id, name, subtitle, item: resultItem ?? null };
      })
      .toSorted((a, b) => a.name.localeCompare(b.name));

    return { category, label: CATEGORY_LABELS[category] ?? category, entries };
  })
  .filter((section) => section.entries.length > 0);

const totalRecipes = recipeEntries.length;
---

<MainLayout title="Craftalog - A Minecraft Recipe Catalog">
  <div class="catalog">
    <div class="catalog__header">
      <h1 class="catalog__title">All Crafting Recipes</h1>
      <p class="catalog__subtitle">
        {totalRecipes} recipes cataloged from Minecraft {meta.version}
      </p>
    </div>

    <form class="catalog__filter" role="search">
      <label for="recipe-filter" class="catalog__filter-label">Filter recipes by name</label>
      <input
        type="search"
        id="recipe-filter"
        class="catalog__filter-input"
        placeholder="Search recipes…"
        autocomplete="off"
      />

      <div class="catalog__categories" role="radiogroup" aria-label="Filter by category">
        <input
          type="radio"
          name="category"
          id="category-all"
          value="all"
          checked
          class="catalog__category-input"
        />
        <label for="category-all" class="catalog__category-pill">
          All <span class="catalog__category-count">({totalRecipes})</span>
        </label>
        {
          sections.map((section) => (
            <>
              <input
                type="radio"
                name="category"
                id={`category-${section.category}`}
                value={section.category}
                class="catalog__category-input"
              />
              <label for={`category-${section.category}`} class="catalog__category-pill">
                {section.label}{' '}
                <span class="catalog__category-count">({section.entries.length})</span>
              </label>
            </>
          ))
        }
      </div>
    </form>

    <p id="catalog-empty" class="catalog__empty" hidden>No recipes match your search.</p>

    {
      sections.map((section) => (
        <section class="catalog__section" data-category-section>
          <h2 class="catalog__section-title">
            {section.label} <span class="catalog__section-count">({section.entries.length})</span>
          </h2>
          <ul class="catalog__grid">
            {section.entries.map((entry) => (
              <li
                class="catalog__item"
                data-search={entry.name.toLowerCase()}
                data-category={section.category}
              >
                <a href={withBase(`/recipe/${entry.id}/`)} class="catalog__link">
                  <span class="catalog__icon">
                    <ItemIcon item={entry.item} />
                  </span>
                  <span class="catalog__text">
                    <span class="catalog__name">{entry.name}</span>
                    {entry.subtitle && <span class="catalog__item-subtitle">{entry.subtitle}</span>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</MainLayout>

<script>
  // astro:page-load fires on the initial load AND every subsequent View
  // Transitions navigation, so re-querying/re-binding here keeps this working
  // when navigating back to this page via the client router.
  document.addEventListener('astro:page-load', () => {
    const input = document.getElementById('recipe-filter');
    const items = document.querySelectorAll<HTMLElement>('.catalog__item');
    const sections = document.querySelectorAll<HTMLElement>('[data-category-section]');
    const categoryInputs = document.querySelectorAll<HTMLInputElement>('input[name="category"]');
    const emptyState = document.getElementById('catalog-empty');

    let activeCategory = 'all';

    function applyFilter(query: string) {
      const needle = query.trim().toLowerCase();
      let anyVisible = false;

      items.forEach((item) => {
        const matchesText = !needle || (item.dataset.search ?? '').includes(needle);
        const matchesCategory =
          activeCategory === 'all' || item.dataset.category === activeCategory;
        const visible = matchesText && matchesCategory;
        item.hidden = !visible;
        if (visible) anyVisible = true;
      });

      sections.forEach((section) => {
        const visibleItems = section.querySelectorAll('.catalog__item:not([hidden])');
        section.hidden = visibleItems.length === 0;
      });

      if (emptyState) emptyState.hidden = anyVisible;
    }

    if (input instanceof HTMLInputElement) {
      input.addEventListener('input', () => applyFilter(input.value));
    }

    categoryInputs.forEach((radio) => {
      radio.addEventListener('change', () => {
        if (radio.checked) {
          activeCategory = radio.value;
          applyFilter(input instanceof HTMLInputElement ? input.value : '');
        }
      });
    });
  });
</script>

<style>
  .catalog__header {
    margin-bottom: var(--space-4);
  }

  .catalog__subtitle {
    margin-top: var(--space-2);
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  .catalog__filter {
    margin-bottom: var(--space-8);
  }

  .catalog__filter-label {
    display: block;
    margin-bottom: var(--space-2);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .catalog__filter-input {
    width: 100%;
    max-width: 24rem;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    font-size: 1rem;
    font-family: var(--font-sans);
  }

  .catalog__filter-input:focus {
    outline: 2px solid var(--color-fg);
    outline-offset: 1px;
  }

  .catalog__categories {
    margin-top: var(--space-3);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .catalog__category-input {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
  }

  .catalog__category-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 0.8125rem;
    color: var(--color-muted);
    cursor: pointer;
    user-select: none;
    transition: all 0.15s;
  }

  .catalog__category-input:checked + .catalog__category-pill {
    background-color: var(--color-fg);
    border-color: var(--color-fg);
    color: var(--color-bg);
  }

  .catalog__category-input:focus-visible + .catalog__category-pill {
    outline: 2px solid var(--color-fg);
    outline-offset: 2px;
  }

  .catalog__category-count {
    color: inherit;
    opacity: 0.7;
  }

  .catalog__empty {
    margin-bottom: var(--space-8);
    color: var(--color-muted);
  }

  .catalog__section + .catalog__section {
    margin-top: var(--space-8);
  }

  .catalog__section-count {
    color: var(--color-muted);
    font-weight: 400;
  }

  .catalog__grid {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(9.5rem, 1fr));
    gap: var(--space-2);
  }

  .catalog__link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    height: 100%;
    min-height: 3.5rem;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    transition: all 0.2s;
  }

  .catalog__link:hover {
    border-color: var(--color-fg);
    background-color: white;
  }

  .catalog__icon {
    display: block;
    width: 2rem;
    flex-shrink: 0;
    image-rendering: pixelated;
  }

  .catalog__text {
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 0.125rem;
  }

  .catalog__name {
    font-size: 0.875rem;
    text-wrap: balance;
  }

  .catalog__item-subtitle {
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: capitalize;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
