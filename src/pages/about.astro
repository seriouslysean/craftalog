---
import MainLayout from '../layouts/MainLayout.astro';
import { withBase } from '../utils/with-base';
import meta from '../data/generated/meta.json';
---

<MainLayout title="About - Craftalog">
  <div class="about">
    <h1 class="about__title">About Craftalog</h1>
    <p class="about__paragraph">
      Craftalog catalogs every vanilla Minecraft crafting recipe — {meta.counts.shaped} shaped, {
        meta.counts.shapeless
      } shapeless, {meta.counts.transmute} transmute, and {meta.counts.special} hardcoded "special" recipes
      — currently sourced from Minecraft {meta.version}.
    </p>
    <p class="about__paragraph">
      Recipe and item data is parsed from <a href="https://github.com/misode/mcmeta"
        >misode/mcmeta</a
      >
      and kept up to date automatically — nothing here is hand-authored, so the catalog stays accurate
      as new versions ship.
    </p>
    <p class="about__paragraph">
      Furnace, stonecutter, and smithing table recipes aren't covered yet — this catalog is scoped
      to the crafting table for now.
    </p>
    <p class="about__paragraph">
      <a href={withBase('/')}>Browse all recipes</a>
    </p>
  </div>
</MainLayout>

<style>
  .about__title {
    margin-bottom: var(--space-6);
  }

  .about__paragraph {
    max-width: 40rem;
  }

  .about__paragraph + .about__paragraph {
    margin-top: var(--space-4);
  }
</style>
