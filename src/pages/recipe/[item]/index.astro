---
import { getCollection } from 'astro:content';
import RecipePage from '../../../components/RecipePage.astro';
import {
  buildRecipeHrefMap,
  collapseVariantGroups,
  groupDisplayName,
  groupItemSlug,
  groupRecipes,
} from '../../../utils/recipe-groups';
import { buildPagerSequence, pagerNeighbors } from '../../../utils/recipe-pager';

export async function getStaticPaths() {
  const recipeEntries = await getCollection('recipes');
  const itemEntries = await getCollection('items');
  const itemsMap = new Map(itemEntries.map((entry) => [entry.id, entry.data]));
  const recipesById = new Map(recipeEntries.map((entry) => [entry.id, entry.data]));
  const getItemName = (id: string) => itemsMap.get(id)?.name ?? id;

  const groups = groupRecipes(
    recipeEntries.map((entry) => entry.data),
    getItemName,
  );
  const pagerSequence = buildPagerSequence(groups, itemsMap);
  const recipeHrefs = buildRecipeHrefMap(groups, itemsMap);
  const { variantGroups } = collapseVariantGroups(groups);
  const variantGroupByResultId = new Map(
    variantGroups.flatMap((variantGroup) =>
      variantGroup.variants.map((variant) => [variant.resultId, variantGroup]),
    ),
  );

  // Every group's canonical recipe is reachable at the bare /recipe/{item}/
  // path -- non-canonical siblings live at /recipe/{item}/{slug}/ instead
  // (see src/pages/recipe/[item]/[slug].astro).
  return groups.map((group) => {
    const recipe = recipesById.get(group.canonicalId)!;
    const displayName = groupDisplayName(group, itemsMap);
    const itemSlug = groupItemSlug(group, itemsMap);

    return {
      params: { item: itemSlug },
      props: {
        recipe,
        displayName,
        itemsMap,
        recipeHrefs,
        itemSlug,
        canonicalId: group.canonicalId,
        siblings: group.siblings,
        variantGroup: variantGroupByResultId.get(group.resultId),
        ...pagerNeighbors(pagerSequence, group.canonicalId),
      },
    };
  });
}

const props = Astro.props;
---

<RecipePage {...props} />
