{
  "name": "craftalog",
  "version": "0.0.0",
  "private": true,
  "description": "Craftalog - A Minecraft Recipe Catalog",
  "author": {
    "name": "Sean Kennedy",
    "email": "sean@codeserious.com",
    "url": "http://www.codeserious.com"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint .",
    "format": "oxfmt . && prettier --write \"**/*.astro\" --log-level warn",
    "format:check": "oxfmt --check . && prettier --check \"**/*.astro\" --log-level warn",
    "type-check": "astro check && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "parse": "tsx scripts/parse.ts",
    "validate": "tsx scripts/validate.ts",
    "vendor:init": "git submodule update --init --depth 1"
  },
  "dependencies": {
    "@fontsource/pixelify-sans": "5.2.7",
    "astro": "7.0.9",
    "modern-normalize": "3.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "24.13.3",
    "@types/pngjs": "6.0.5",
    "oxfmt": "0.58.0",
    "oxlint": "1.74.0",
    "pngjs": "7.0.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24"
  }
}
