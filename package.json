{
  "name": "craftalog",
  "version": "0.0.0",
  "private": true,
  "description": "Craftalog - A Minecraft Recipe Catalog",
  "author": {
    "name": "Sean Kennedy",
    "email": "sean@codeserious.com",
    "url": "http://www.codeserious.com"
  },
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint .",
    "format": "oxfmt . && prettier --write \"**/*.astro\" --log-level warn",
    "format:check": "oxfmt --check . && prettier --check \"**/*.astro\" --log-level warn",
    "type-check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "parse": "tsx scripts/parse.ts",
    "validate": "tsx scripts/validate.ts",
    "vendor:init": "git submodule update --init --depth 1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^7.0.6",
    "modern-normalize": "^3.0.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
